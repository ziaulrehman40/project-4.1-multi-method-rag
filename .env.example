GEMINI_API_KEY=replace-me
DATABASE_URL=postgresql://USER:PASS@localhost:5432/multi_method_rag
DJANGO_SECRET_KEY=replace-with-a-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_LOG_LEVEL=DEBUG
# Optional: bootstrap a superuser on startup (used by `ensure_superuser`,
# needed on hosts without shell access like Render free tier). Leave unset locally.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=
