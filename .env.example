GEMINI_API_KEY=replace-me
# Generation model when the Gemini provider is used (chat, rerank, RAG answers).
GEMINI_MODEL=gemini-2.5-flash-lite

# LLM provider selection (see the llm/ adapter). Generation is swappable; embeddings stay
# on Gemini (pgvector columns are dimension-locked at 3072). Flip generation with one var:
LLM_GENERATION_PROVIDER=gemini
# LLM_EMBEDDING_PROVIDER=gemini
# To use Groq for generation (higher free limits, incl. vision): set the above to "groq"
# and provide a key. One Groq model handles text/JSON/vision for a fair comparison.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b
DATABASE_URL=postgresql://USER:PASS@localhost:5432/multi_method_rag
DJANGO_SECRET_KEY=replace-with-a-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_LOG_LEVEL=DEBUG
# Optional: bootstrap a superuser on startup (used by `ensure_superuser`,
# needed on hosts without shell access like Render free tier). Leave unset locally.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=
