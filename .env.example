GEMINI_API_KEY=replace-me
# Generation model when the Gemini provider is used (chat, rerank, RAG answers).
GEMINI_MODEL=gemini-2.5-flash-lite

# LLM provider selection (see the llm/ adapter). Generation is swappable; embeddings stay
# on Gemini (pgvector columns are dimension-locked at 3072). Flip generation with one var:
LLM_GENERATION_PROVIDER=gemini
# LLM_EMBEDDING_PROVIDER=gemini
# To use Groq for generation (higher free limits, incl. vision): set the above to "groq"
# and provide a key. One Groq model handles text/JSON/vision for a fair comparison.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b
# Or use OpenAI (paid; generous limits, reliable JSON + vision, all figures fit):
# set LLM_GENERATION_PROVIDER=openai and provide a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Abuse/cost guardrails. MAX_QUESTION_CHARS bounds prompt size; GENERATION_MAX_TOKENS bounds
# generated output per call (so no single request runs up an unbounded token bill). Defaults
# are sensible; override only if answers need more room. (Groq keeps its own GROQ_MAX_TOKENS.)
# MAX_QUESTION_CHARS=2000
# GENERATION_MAX_TOKENS=2048

# One-time forced rebuild without shell access (Render): bump this to any new value to make
# the next boot re-extract the knowledge graph once under the current generation provider
# (the only generation-derived artifact — embeddings stay on Gemini). Handled by
# `apply_rebuild`; the value is latched in the DB so it fires exactly once. Leave unset normally.
REBUILD_VERSION=

# The evaluation run is established automatically on deploy if none exists yet (via
# `ensure_eval`, backgrounded so it never blocks boot). Bump EVAL_VERSION to force a fresh
# eval on the next deploy (e.g. after changing the corpus or the generation provider).
EVAL_VERSION=

DATABASE_URL=postgresql://USER:PASS@localhost:5432/multi_method_rag
DJANGO_SECRET_KEY=replace-with-a-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_LOG_LEVEL=DEBUG
# Optional: bootstrap a superuser on startup (used by `ensure_superuser`,
# needed on hosts without shell access like Render free tier). Leave unset locally.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=
